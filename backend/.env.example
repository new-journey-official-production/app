# --- Render Dashboard (Production) — set these as separate env vars ---
# DatabaseUrl=Host=aws-0-REGION.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.YOUR_REF;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
# JwtSecret=generate-a-long-random-string-at-least-32-chars
# CorsOrigins=https://store.newjourneyofficial.com,https://nj-store-tan.vercel.app
# AdminEmail=you@yourdomain.com
# AdminPassword=YourSecurePassword123!
# SupabaseUrl=https://YOUR_REF.supabase.co
# SupabasePublishableKey=your-publishable-or-anon-key
# ASPNETCORE_ENVIRONMENT=Production

# --- Local dev defaults below ---
JwtSecret=local-dev-secret-change-in-production
CorsOrigins=http://localhost:30000,http://localhost:3000
AdminEmail=admin@newjourney.com
AdminPassword=Admin@12345

SupabaseUrl=https://your-project.supabase.co
SupabasePublishableKey=your-publishable-or-anon-key
