# New Journey Backend — environment template
# Copy values to Render env vars or appsettings.Development.json (local, gitignored)

# Local dev — direct connection (IPv6) is fine on most machines:
# DatabaseUrl=Host=db.your-project.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Render / Vercel — paste ONLY this single line as DatabaseUrl (NOT JSON, NOT appsettings):
# DatabaseUrl=Host=aws-0-REGION.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.your-project-ref;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

JwtSecret=change-me-in-production
CorsOrigins=http://localhost:3000
AdminEmail=admin@newjourney.com
AdminPassword=Admin@12345
DemoCustomerEmail=customer@newjourney.com
DemoCustomerPassword=Customer@12345

# Supabase REST (health checks / publishable key)
SupabaseUrl=https://your-project.supabase.co
SupabasePublishableKey=your-publishable-or-anon-key
